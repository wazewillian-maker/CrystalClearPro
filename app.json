{
  "expo": {
    "name": "CrystalClearPro",
    "slug": "CrystalClearPro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/branding/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1B2E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1B2E",
        "foregroundImage": "./assets/branding/icon.png",
        "backgroundImage": "./assets/branding/icon.png",
        "monochromeImage": "./assets/branding/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/branding/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permita que o Crystal Clear Pro use a camera para registrar as fotos do atendimento.",
          "photosPermission": "Permita que o Crystal Clear Pro acesse suas fotos para registrar o atendimento."
        }
      ]
    ]
  }
}
